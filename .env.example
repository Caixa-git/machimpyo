# ─── Supabase ───────────────────────────────────────────────
# Find these in your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (Email) ─────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── App ────────────────────────────────────────────────────
# Used in email templates for links; no trailing slash
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── Toss Payments ───────────────────────────────────────────
# Get your keys from https://dashboard.tosspayments.com
# Test keys are used by default — replace with live keys for production
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
TOSS_SECRET_KEY=test_sk_Z1Q2pe8N8qKaN2wRwX3W7bGNY0qy
